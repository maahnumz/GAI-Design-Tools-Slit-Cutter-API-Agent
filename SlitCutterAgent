BBox = namedtuple('BBox', ['min_x', 'min_y', 'max_x', 'max_y'])

# Constants
SLIT_WIDTH_MM = 50.0                  # CHANGED: was THUMBHOLE_DIAMETER_MM = 20.0
SLIT_RX_MM = SLIT_WIDTH_MM / 2.0     # CHANGED: was THUMBHOLE_RADIUS_MM = THUMBHOLE_DIAMETER_MM / 2.0
SLIT_HEIGHT_MM = 3.0                  # CHANGED: new constant
SLIT_RY_MM = SLIT_HEIGHT_MM / 2.0    # CHANGED: new constant
SLIT_OFFSET_FROM_BOTTOM_MM = 8.0     # CHANGED: was THUMBHOLE_OFFSET_FROM_BOTTOM_MM = 15.0
PX_PER_MM = 3.7795275591  # 96 DPI
MIN_DIMENSION_MM = 45.0              # CHANGED: was 25.0

SVG_NS = 'http://www.w3.org/2000/svg'
XLINK_NS = 'http://www.w3.org/1999/xlink'

# We need to preserve namespaces properly
NAMESPACES = {
    'svg': SVG_NS,
    'xlink': XLINK_NS,
    'inkscape': 'http://www.inkscape.org/namespaces/inkscape',
